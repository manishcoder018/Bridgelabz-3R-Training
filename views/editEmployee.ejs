<!DOCTYPE html>
<html>
<head>
  <title>Edit Employee</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="navbar">
  <h2>EMPLOYEE PAYROLL</h2>
  <div>
    <a href="/dashboard">Dashboard</a>
    <a href="/logout">Logout</a>
  </div>
</div>

<div class="container">
  <h2>Edit Employee</h2>

  <form action="/employees/edit/<%= employee.id %>" method="POST">

    <label>Name:</label><br>
    <input type="text" name="name" value="<%= employee.name %>" required><br><br>

    <label>Gender:</label><br>
    <input type="radio" name="gender" value="Male" <%= employee.gender==="Male"?"checked":"" %>> Male
    <input type="radio" name="gender" value="Female" <%= employee.gender==="Female"?"checked":"" %>> Female<br><br>

    <label>Department:</label><br>
    <input type="checkbox" name="department" value="HR"> HR
    <input type="checkbox" name="department" value="Sales"> Sales
    <input type="checkbox" name="department" value="Finance"> Finance<br><br>

    <label>Salary:</label><br>
    <input type="number" name="salary" value="<%= employee.salary %>" required><br><br>

    <button type="submit" class="add-btn">Update</button>

  </form>

</div>

</body>
</html>